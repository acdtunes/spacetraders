# SpaceTraders Go Bot Configuration
# Copy this file to config.yaml and adjust values as needed
#
# Configuration priority (highest to lowest):
# 1. Environment variables (ST_* prefix)
# 2. This config file
# 3. Default values

# Database configuration
database:
  # Database type: postgres or sqlite
  type: postgres

  # Option 1: Full connection URL (takes precedence)
  # url: postgresql://user:password@localhost:5432/spacetraders

  # Option 2: Individual connection fields (used if url is empty)
  host: localhost
  port: 5432
  user: spacetraders
  password: dev_password
  name: spacetraders
  sslmode: disable  # disable, require, verify-ca, verify-full

  # SQLite configuration (if type: sqlite)
  # path: ./spacetraders.db  # Use ":memory:" for in-memory database

  # Connection pool settings
  pool:
    max_open: 25          # Maximum number of open connections
    max_idle: 5           # Maximum number of idle connections
    max_lifetime: 5m      # Maximum connection lifetime (e.g., 5m, 1h)

# SpaceTraders API configuration
api:
  base_url: https://api.spacetraders.io/v2
  timeout: 30s          # Request timeout (e.g., 30s, 1m)

  # Rate limiting (to respect API limits)
  # NOTE: display-only today — the client uses api.RateLimitPerSecond (2/s) and
  # api.RateLimitBurst (30); these keys surface in `config show`, not the limiter.
  rate_limit:
    requests: 2         # Requests per second
    burst: 30           # Burst capacity (matches the live limiter)

  # Retry configuration
  retry:
    max_attempts: 3     # Maximum retry attempts
    backoff_base: 1s    # Base backoff duration

# Routing service configuration (OR-Tools)
routing:
  address: localhost:50051  # gRPC service address

  # Path to the fitted market-model artifact the multi-hop tour executor reads at
  # launch (sp-1ek0). Resolved to an absolute path against THIS config file's
  # directory: leave empty to default to
  # <config-dir>/services/routing-service/model_artifacts/market_model.json (correct
  # in dev and deploy, since config.yaml and services/ ship together); a relative
  # value resolves against the config dir; an absolute value is used as-is. This must
  # be readable regardless of the daemon's working directory.
  # model_artifact_path: ""

  # Operation timeouts
  timeout:
    connect: 10s        # Connection timeout
    dijkstra: 30s       # Pathfinding timeout
    tsp: 60s            # TSP solver timeout
    vrp: 120s           # VRP solver timeout

# Daemon configuration
daemon:
  address: localhost:50052              # gRPC server address
  socket_path: /tmp/spacetraders-daemon.sock  # Unix socket path
  pid_file: /tmp/spacetraders-daemon.pid      # PID file location
  max_containers: 100                   # Maximum concurrent containers
  health_check_interval: 30s            # Health check interval
  shutdown_timeout: 30s                 # Graceful shutdown timeout
  # ships.version conflict resolution (sp-01wc). On a concurrent-writer conflict
  # a scheduler mutation is re-applied on the fresh row instead of last-write-
  # wins clobbering the other writer. Live by default; tune or disable below.
  # max_cas_retries: 3                  # 0/unset → built-in default (3)
  # cas_retry_disabled: false           # true → legacy last-write-wins (sp-60ff)

  # Container restart policy
  restart_policy:
    enabled: true                       # Enable automatic restart on failure
    max_attempts: 3                     # Maximum restart attempts
    delay: 5s                           # Delay between attempts
    backoff_multiplier: 2.0             # Backoff multiplier

# Logging configuration
logging:
  level: info          # debug, info, warn, error
  format: json         # json, text
  output: stdout       # stdout, stderr, file

  # File output configuration (if output: file)
  file_path: /var/log/spacetraders/daemon.log

  # Log rotation
  rotation:
    enabled: true      # Enable rotation
    max_size: 100      # Maximum size in MB before rotation
    max_backups: 3     # Maximum number of old files to keep
    max_age: 28        # Maximum age in days before deletion
    compress: true     # Compress rotated files

  # Additional options
  include_caller: false      # Include file:line in logs
  include_stacktrace: false  # Include stack traces for errors

# Autonomous watchkeeper supervisor (cmd/watchkeeper)
captain:
  enabled: false           # master switch; also see captain/DISABLED kill-switch file
  player_id: 1             # which player the captain commands
  workspace_dir: ../captain
  claude_bin: claude       # local Claude Code CLI (Max subscription; never set ANTHROPIC_API_KEY)
  model: opus
  poll_interval_seconds: 30
  heartbeat_minutes: 45
  max_sessions_per_hour: 6
  session_timeout_minutes: 10
  ship_idle_minutes: 30
  stale_heartbeat_minutes: 5
  credits_thresholds: [100000, 250000, 500000, 1000000]
  # Self-improvement pipeline (phases 3-4; see DISABLED_FIXES kill switch)
  auto_merge: false            # true = merge+restart after gate passes; false = leave branch for human
  max_fixes_per_day: 3
  max_features_per_day: 1
  fix_session_timeout_minutes: 30
  max_feature_diff_lines: 400
  repo_dir: .                  # gobot repo root (worktrees are created under it)
  restart_cmd: make restart-daemon

# Contract fleet coordinator configuration
contract:
  # Idle-gap arbitrage harvest (sp-1z2h / sp-uohe): the contract fleet's
  # dedicated hulls sit idle ~89% of wall-time; this harvests that idle time
  # with hub-local one-shot guarded arb legs. Every value below is OPTIONAL —
  # an unset key takes the documented default.
  #
  # THIS SECTION IS LIVE (sp-ts82). The daemon resolves these knobs from THIS
  # file every time it builds the contract coordinator command — at creation AND
  # at restart recovery. So the retune path is: edit a value here, restart the
  # daemon. That is all — even an already-running coordinator picks up the change
  # on the next boot; you never recreate the coordinator. (Before sp-ts82 a
  # recovered coordinator re-adopted its stale persisted knobs and the edit
  # silently no-op'd.) config.yaml is the single source of truth; the values the
  # daemon persists into the coordinator's launch config are dead. No hot-reload:
  # a running daemon does not watch this file — the edit lands on restart.
  idle_arb:
    # disabled: true turns the harvest off entirely (default: on wherever a
    # dedicated contract fleet exists).
    # disabled: false
    reserve_hulls: 1           # idle hulls never leased to arb, reserved for instant contract claims (default 1)
    hub_radius: 250            # outer hub-local filter: max sell-leg distance from the hub (default 250)
    # sp-uohe money guards — the −234k ELECTRONICS bleed fix. Fail CLOSED, never weakened.
    leash_radius: 80           # tight leash: max sell-leg distance from the hub (default 80; legs naturally max ~52u)
    max_leg_seconds: 480       # projected per-leg CRUISE flight-time cap (default 480 = 8 min)
    max_spend: 100000          # per-leg buy cap (default 100k)
    min_margin: 1              # ABSOLUTE per-unit margin floor handed to the arb run (default 1)
    margin_verify_pct: 80      # RELATIVE floor: abort pre-buy unless the LIVE margin holds >= this % of the quoted margin (default 80)
    interval_seconds: 90       # dispatch tick (default 90)
    # blacklist: goods the harvest never dispatches (checked at dispatch time).
    # Absent → default [ELECTRONICS] (the good that bled −234k). To RE-ENABLE a
    # blacklisted good, edit this list and restart — e.g. set `blacklist: []`
    # to clear it, or list other goods. An explicit empty list disables the
    # blacklist entirely.
    blacklist:
      - ELECTRONICS

  # Contract-goods pre-positioning (sp-dchv Lane C): the trade-tour engine buys
  # goods the contract history recurrently needs — where they are CHEAP in a
  # reachable foreign system — and DEPOSITS them into the home warehouse (Lane B),
  # so home-system contract workers later source inventory-first at zero ask. The
  # solver prices each deposit against real arb sells (synthetic bid = home_ask),
  # so hold space goes to whichever earns more. Deposits book NO cash revenue —
  # the value is the future contract-sourcing saving.
  #
  # THIS SECTION IS LIVE (sp-ts82 pattern): the daemon resolves these knobs from
  # THIS file when it builds the tour coordinator — edit a value, restart the
  # daemon. OFF by default; a dedicated warehouse hull (Lane B) must be running in
  # the tour's home system for any deposit candidate to be offered.
  pre_positioning:
    enabled: false             # true turns deposit legs on (default OFF)
    top_n: 5                   # max stock-eligible goods offered as deposit candidates (default 5)
    min_recurrence: 2          # a good must be demanded by >= this many contracts (default 2; RULINGS #6)
    # Pre-positioning capital ceiling — % of LIVE treasury the opportunistic tour
    # deposit legs may tie up in warehouse inventory. This is the ENABLEMENT knob
    # (sp-13tl): 0/absent => PARKED (dormant, fail closed, no deposits — money
    # movement is a captain/analyst decision, RULINGS #5). Set a positive value to
    # authorize it. Junior to trade_fleet.working_capital_reserve and the sp-w3he
    # cross-container cap; an unreadable balance => ceiling 0 => no candidates
    # (fail closed, RULINGS #4).
    # capital_ceiling_pct: 10    # e.g. 10% of live treasury (absent => parked)
    min_savings_per_unit: 1    # home_ask - foreign_ask must clear this per unit (default 1)
    # allowlist: restrict deposits to exactly these goods (after eligibility).
    # Absent => every stock-eligible good qualifies. Example:
    # allowlist:
    #   - ELECTRONICS
    #   - EQUIPMENT
    # blocklist: goods NEVER deposited (wins over allowlist). Absent => none.
    # blocklist:
    #   - FUEL

  # Parked-hull auto-liquidation (sp-39oi): a hull the spawn filter parks for holding
  # cargo unrelated to the active contract (a leftover strand from a mid-crisis
  # floor/margin/max-spend abort) self-clears via a one-shot cargo_liquidation worker —
  # it sells the strand at the best in-system bid so the hull re-enters candidacy,
  # instead of sitting filtered out of the pool forever. This closes the fleet-scale jam
  # where every dual-duty contract hull stranded 6-77u of leftovers and fulfillments fell
  # to zero. No captain hands.
  #
  # THIS SECTION IS LIVE (sp-ts82): the daemon resolves these knobs from THIS file on
  # every coordinator build — creation AND restart recovery. Retune path: edit a value,
  # restart the daemon.
  auto_liquidation:
    # disabled: true turns auto-liquidation OFF (default: ON). Liquidation-by-sale only
    # converts a stranded hold to treasury, so it is on by default.
    # disabled: false
    # min_jettison_value: the value floor (bid * units, credits) below which a leftover
    # lot may be JETTISONED as a last resort — only when no in-system market bids it, or
    # the recoverable value is below this floor. 0/absent => jettison OFF: nothing is ever
    # destroyed without an explicit floor, and any lot with a bid is always SOLD (value
    # recovered, never dumped). Set a positive value to let the worker clear genuinely
    # stuck low-value junk off a hull. The captain's 3 valuable ~150k holds clear the
    # floor at any sane value and are always sold.
    # min_jettison_value: 0

# Trade-fleet coordinator (sp-1278): the standing coordinator that keeps continuous
# tours alive on every 'trade'-dedicated hull. When a tour makes an honest exit
# (margins died in both systems, or a sold-out completion) the hull parks; this
# coordinator relaunches a fresh continuous tour on it after a per-hull cooldown that
# lets the local ground breathe (the rich->tapped->rich cycle). It retires the captain's
# hand-relaunch loop. Launch it once with `spacetraders workflow trade-fleet-coordinator`.
#
# THIS SECTION IS LIVE (sp-ts82): the daemon resolves these knobs from THIS file every
# time it builds the coordinator — at creation AND at restart recovery. Retune path: edit
# a value, restart the daemon; even an already-running coordinator picks up the change on
# the next boot (no recreate). Every value is OPTIONAL — an unset key takes the documented
# default. Ownership is untouched: each tour claims its own hull under operation="trade";
# a captain-reserved hull is skipped, and unpinning a hull from the 'trade' fleet removes
# it from the coordinator's view with no restart.
trade_fleet:
  # enabled: false parks the WHOLE relaunch loop without unpinning any hull. Absent =>
  # ON (the coordinator's purpose is to keep every trade hull touring).
  # enabled: false
  cooldown_seconds: 180        # per-hull wait after an honest exit before relaunch (default 180 = 3 min)
  # max_concurrent_tours caps simultaneously-running trade tours. 0 (default) = unlimited,
  # bounded only by fleet size — every idle trade hull is relaunched. Set a positive cap
  # to bound concurrent capital deployment / API load (a capped fleet larger than the cap
  # will leave surplus hulls parked, honest, until a running tour frees a slot).
  max_concurrent_tours: 0
  tick_seconds: 30             # reconcile cadence (default 30)
  # Per-tour caps, passed verbatim to each tour launch. 0 => the tour's own default
  # (max_hops->6, max_spend->25% of live treasury, replan_limit->2, reserve->the floor).
  # Iterations is NOT configurable: every relaunched tour is continuous by construction.
  # max_hops: 6
  # max_spend: 0
  # min_margin: 0
  # replan_limit: 0
  # working_capital_reserve: 0
  # working_capital_reserve_treasury_pct (sp-yqx4): the counter-cyclical floor as a percent
  # of LIVE treasury. Each tour buy is floored at max(50000, min(working_capital_reserve,
  # pct% x treasury)) so a reserve above the treasury can no longer deadlock the fleet at
  # sub-reserve balances. 0/absent => 40% (deadlock-proof default). Above ~2.5M treasury the
  # absolute reserve binds exactly as before; below it the proportional floor keeps buying
  # feasible while the 50000 lower bound stands.
  # working_capital_reserve_treasury_pct: 40
  # relaunch_backoff_max_minutes (sp-1pli): ceiling for the per-hull ADAPTIVE relaunch
  # backoff. When a hull's continuous tour exits unproductive (fast-fail — no plausible
  # trade leg flown), its relaunch cooldown DOUBLES from cooldown_seconds, up to this
  # ceiling, instead of retrying the full discovery+solver pass every cooldown_seconds
  # forever against a fleet-wide-infeasible market. Any productive exit resets the hull
  # straight back to cooldown_seconds. 0/absent => 30 min.
  # relaunch_backoff_max_minutes: 30

  # stranded_consecutive_threshold (sp-686e): how many CONSECUTIVE origin-level empty
  # reposition discoveries a hull must accrue before the tour coordinator pages the watch.
  # The TORWIND-2C shape — a hull whose origin has NO durable gate adjacency AND a
  # gate-inaccessible (probe-backed-off) live gate — makes BOTH discovery paths return empty,
  # so the hull can never self-reposition and silently relaunch-loops until a human notices.
  # At this many consecutive stranded empties (any successful discovery resets the count), the
  # coordinator emits ONE WARN + the fleet_hull_stranded_total counter (the StrandedHull
  # alert), so the watch is paged for a captain-authority jump/ferry extraction. 0/absent => 3.
  # stranded_consecutive_threshold: 3

  # reposition_jump_bound (sp-kl16): the jump bound a tour reposition resolves its cross-system
  # leg over the PERSISTED stored adjacency (RepositionPath) with, routing PAST an unreadable
  # frontier gate rather than fail-closing on it via the strict fetch-through Path. A tour
  # reposition MOVES the hull to a fresh trading ground (it does not commit money), so — like a
  # scout reposition (scouting.max_reposition_jumps) — it may hop the known topology past a gate
  # in the sp-ikx1 unreadable-backoff set: a heavy whose ORIGIN gate is unreadable (the C1-blocking
  # TORWIND-37/2C -> GQ92 incident, unroutable within the strict 5-jump Path even for a 2-hop
  # route) can still reposition. The buy-side (arb pre-buy, trade-route lane commits, cargo
  # delivery) keeps the strict Path — money-commitment vs hull-movement is the guard line.
  # 0/absent => 12 (matching the scout frontier depth).
  # reposition_jump_bound: 12

# Worker-rebalancer coordinator (sp-f5pr): the STANDING coordinator that ferries idle
# undedicated light-haulers cross-system to worker-starved factory systems, so a factory
# posting "No in-system worker" self-heals without captain hand-holding. A system is a
# vacancy when a factory has run past vacancy_min_minutes with NO in-system idle light and
# fewer lights than factory chains; the coordinator jump-routes the nearest idle light from
# a source with a spare and reclaims it on arrival for the factory to man in-system. Launch
# it once with `spacetraders workflow worker-rebalancer-coordinator` (add --dry-run first to
# preview). It derives ALL state from ship + container rows — zero new persisted state, so a
# daemon restart resumes identically.
#
# THIS SECTION IS LIVE (sp-ts82): the daemon resolves these knobs from THIS file every time
# it builds the coordinator — at creation AND at restart recovery. Every value is OPTIONAL;
# an unset key takes the documented default. Ownership is untouched: each ferry claims its
# own hull under operation="worker_ferry" (occupancy, not a dedication); pinned and
# captain-reserved hulls are never poached.
worker_rebalancer:
  # enabled: false parks the WHOLE ferry loop. Absent => ON.
  # enabled: false
  tick_seconds: 60                 # reconcile cadence (default 60)
  vacancy_min_minutes: 15          # factory warm-up before a system counts as starved (default 15)
  source_min_idle: 2               # idle lights a source must hold to donate one (default 2; never strips below 1)
  ferry_cooldown_seconds: 600      # per-system suppress window after a ferry targets it (default 600)
  max_concurrent_ferries: 2        # cap on simultaneously-running ferries (default 2)
  max_lights_per_system: 0         # per-system light cap incl. in-flight ferries (0 = uncapped, default)

# Manufacturing coordinators (sp-kk61): working_capital_reserve is the factory
# input-buy spend floor. goods_factory_coordinator enforces it immediately — the
# effective floor at every input purchase is max(50000, working_capital_reserve),
# the 50000 an immutable lower bound (sp-agzj). manufacturing_coordinator (the
# parallel task-based pipeline coordinator) carries the same value through for
# reachability, but its purchaser does not yet enforce a floor at purchase time
# (tracked as a follow-up).
#
# THIS SECTION IS LIVE (sp-ts82 pattern): resolved from THIS file on every
# coordinator build — creation AND restart recovery — so a retune reaches an
# already-running coordinator after a daemon restart, no redeploy needed.
# Absent/0 => goods_factory_coordinator's standing 50k floor; unset here matches
# a fleet with no [manufacturing] section at all (pre-sp-kk61 behavior, unchanged).
manufacturing:
  # working_capital_reserve: 0
  # working_capital_reserve_treasury_pct (sp-yqx4): the counter-cyclical floor as a percent
  # of LIVE treasury for goods_factory_coordinator input buys — each buy is floored at
  # max(50000, min(working_capital_reserve, pct% x treasury)) so a factory below ~2.5M
  # treasury is not deadlocked by a reserve above its balance. 0/absent => 40% default.
  # working_capital_reserve_treasury_pct: 40
  #
  # chain_pnl_kill_threshold_per_hour (sp-rh2z): the realized-P&L/hr floor below which a chain
  # AUTO-PAUSES. The goods_factory coordinator computes each chain's realized P&L over the
  # rolling window (factory local sells + tour realized net - input cost - lift) and pauses the
  # chain pre-spend when it falls below this figure, resuming automatically when the window
  # recovers — the portfolio becomes self-pruning. Fails OPEN (an accounting outage never halts
  # production; the switch can only stop spend). 0/absent => 30000/hr default (the switch is ON
  # in production without naming it here). chain_pnl_window_hours: the trailing window, 0/absent
  # => 6h. chain_pnl_kill_disabled: emergency off-switch (RULINGS #5) to keep a chain running
  # through an accounting gap.
  # chain_pnl_kill_threshold_per_hour: 30000
  # chain_pnl_window_hours: 6
  # chain_pnl_kill_disabled: false
  #
  # input_recovery_reattempt_minutes (sp-r5a6): the input-poison anti-cycle's recovery half-life.
  # When a chain's input layer goes ineligible (no MODERATE+ in-system supply source for a
  # required input — the a5j7 leading indicator), the goods_factory coordinator PAUSES the chain
  # and holds it OFF the market for this many minutes before a one-iteration re-attempt through
  # the launch guards (a still-poisoned layer re-pauses at zero cost; a recovered layer proceeds).
  # This is the INPUT side of the self-pruning portfolio (chain_pnl_kill is the OUTPUT side): it
  # stops early-recovery buys from re-poisoning a just-regenerating well. 0/absent => 194min
  # default (the analyst's measured half-life; the anti-cycle is ON in production without naming it
  # here — it can only STOP spend). anti_cycle_disabled: emergency off-switch (RULINGS #5) reverting
  # to the selector's park-and-retry.
  # input_recovery_reattempt_minutes: 194
  # anti_cycle_disabled: false
  #
  # fabricate_max_depth (sp-jav2 / FACTORY_DOCTRINE X1): how deep the SupplyChainResolver
  # fabricates before resolving an input to a market-BUY. Root is depth 0, its direct inputs
  # depth 1; a node past this depth is bought, not fabricated into its own sub-chain. Recursive
  # fabricate ladders past depth-1 are dead weight — raw inputs are ~0.29% of spend, market-buy
  # was ruled the permanently-correct acquisition (sp-naw6, flip conditions never fired across 397
  # markets), and the furnace class of losses lived in the recursion. 0/absent => depth-1 default
  # ("buy inputs, lift output"); the cap is ON in production without naming it here — it only
  # redirects an input from fabrication to a market-buy, never money movement. fabricate_depth_cap_disabled:
  # emergency off-switch (RULINGS #5) restoring the original unbounded recursion.
  # fabricate_max_depth: 1
  # fabricate_depth_cap_disabled: false

# Scouting subsystem (sp-x8i5): phase-jitter to keep a large scout fleet's tour
# rotations decohered. ~45 scouts restarting their rotation in near-lockstep
# transiently saturated the rate limiter — the 2026-07-11 00:56-01:02Z burst showed
# p99 limiter wait plateaued ~4s and Purchase Cargo p99 at 9.5s, while 15m-average
# utilization read a calm 53% (a phase-locked wave, not a sustained-load problem).
#
# THIS SECTION IS LIVE (sp-ts82 pattern): resolved from THIS file on every scout_tour
# / scout_post_coordinator build — creation AND restart recovery — so a retune reaches
# an already-running fleet after a daemon restart, no redeploy needed.
scouting:
  # tour_start_jitter_max_seconds bounds the per-ship deterministic phase jitter a
  # scout tour waits before its first navigation/scan, and the standing
  # scout_post_coordinator waits the same way before its reconcile loop starts. Each
  # waits hash(id) % ceiling — deterministic across restarts (no math/rand) — so the
  # fleet decoheres into a spread instead of stacking on every rotation. 0/absent =>
  # 120s, sized so ~45 scouts spread across two effective reconcile ticks without
  # materially delaying any one hull's first scan.
  # tour_start_jitter_max_seconds: 120

  # max_reposition_jumps bounds the EXPENDABLE-probe reposition reach the standing
  # scout_post_coordinator resolves over the PERSISTED stored gate adjacency (sp-8k9m).
  # Both the nearest-satellite selection and the dispatched relay route PAST unreadable
  # frontier gates (which the strict fetch-through router dead-ends on) up to this many
  # jumps, so a probe can reach a post that sits beyond the strict heavy-hull cap
  # (gategraph.MaxJumpPath=5). This is safe ONLY for the expendable scout class: a probe's
  # purpose is to reach an unreadable frontier, and every arrival re-reads the gate it
  # crossed, so the relaxation retires itself. The measured worst-case charted depth from
  # the probe supply to the darkest posts was 6-12 jumps (KN67->SN21=6, ->C81=9, ->XN7=12),
  # so 0/absent => 12. Raising this does NOT relax heavies/trade/arb — they keep MaxJumpPath.
  # max_reposition_jumps: 12

  # heavy_ship_types (sp-42ow) is the set of ship types that count as HEAVY freight for
  # shipyard discovery. The scout tour's piggybacked shipyard scan emits a one-time-per-era
  # milestone captain event (shipyard.heavy_yard_discovered) when a yard selling one of
  # these is first discovered, and the fleet autosizer's nearest-reachable-heavy-yard price
  # fallback keys on the same scans. Empty/absent => the domain default below.
  # heavy_ship_types:
  #   - SHIP_HEAVY_FREIGHTER
  #   - SHIP_BULK_FREIGHTER

# fleet_autosizer (sp-1txd): the standing fleet capacity autosizer — the buy-side twin of the
# siting coordinator. It sizes the hull pool to demand each slow tick and AUTO-BUYS hulls when
# funds clear the full fail-closed money-guard stack. LIVE BY DEFAULT once first-launched
# (`workflow fleet-autosizer`); every knob resolves live on daemon restart (no redeploy). Every
# purchase decision logs its full arithmetic, so retune the blocking knob from the log, not guesswork.
fleet_autosizer:
  # Escapes. autosizer_disabled stands the WHOLE thing down (absent/false = ACTIVE, no dark-shipping);
  # lights_disabled / heavies_disabled freeze one class while the other runs; dry_run evaluates + logs
  # every buy LOUDLY but spends nothing (the zero-effect alarm still fires). warehouse_hulls_enabled
  # is opt-IN (the warehouse class is not live by default).
  # autosizer_disabled: false
  # dry_run: false
  # lights_disabled: false
  # heavies_disabled: false
  # warehouse_hulls_enabled: false

  # Cadence + pacing. tick_interval_secs is the slow sizing cadence (0 => 900s). purchase_cap_per_tick
  # bounds hulls bought per tick across ALL classes (0 => 1) — the treasury protection against a
  # runaway multi-buy.
  # tick_interval_secs: 900
  # purchase_cap_per_tick: 1

  # Fleet ceilings — the HARD API-request-budget bound (each hull adds request load). 0 => the
  # protective defaults (total 50, lights 35, heavies 15, warehouse 8). Raise from evidence.
  # fleet_ceiling_total: 50
  # fleet_ceiling_lights: 35
  # fleet_ceiling_heavies: 15
  # fleet_ceiling_warehouse: 8

  # Treasury guard (reuses common.EffectiveReserveFloor, the sp-yqx4 counter-cyclical floor). A buy
  # fires only if live treasury − reserve floor >= price + purchase_margin_over_floor. margin 0 =>
  # 200000; reserve_treasury_pct 0 => the 40% proportional floor default.
  # purchase_margin_over_floor: 200000
  # reserve: 0
  # reserve_treasury_pct: 40

  # LIGHT (factory-worker) demand. K chains need K x light_rotation_slots workers (inverts the siting
  # C3 rotation math). 0 => 3.5.
  # light_rotation_slots: 3.5

  # HEAVY (trade) demand. heavy_marginal_rate_floor is the fraction of the class's fleet-average
  # realized $/hr the marginal hull must clear (0 => 0.7). heavy_unserved_lanes_min is how many
  # CONSECUTIVE ticks the profitable-lanes-beyond-hulls shortfall must persist before a heavy is bought
  # (0 => 3, anti-thrash). heavy_treasury_pct_per_purchase is the analyst 25%-of-treasury affordability
  # rule per big-ticket buy (0 => 25).
  # heavy_marginal_rate_floor: 0.7
  # heavy_unserved_lanes_min: 3
  # heavy_treasury_pct_per_purchase: 25

  # ERA-CLOCK payback guard — hulls evaporate at reset, so a buy must pay back in-era. Buy only if
  # price <= expected_marginal_rate x hours_to_era_end x payback_safety_factor (0 => 0.5), and NEVER
  # inside the hard last-buy window purchase_cutoff_at_era_minus_hours before reset (0 => 3.0 = T-3h).
  # payback_safety_factor: 0.5
  # purchase_cutoff_at_era_minus_hours: 3.0

  # PRICE ceilings + yard preference. max_price_lights / max_price_heavies cap the absolute price paid
  # (0 => no absolute cap). max_premium_over_cheapest_pct caps the premium over the cheapest known yard
  # ask (0 => 50). prefer_demand_proximal_yard spawns hulls where the demand is, subject to the premium
  # (default TRUE — set false to always take the cheapest yard).
  # max_price_lights: 0
  # max_price_heavies: 0
  # max_premium_over_cheapest_pct: 50
  # prefer_demand_proximal_yard: true

  # Ship types bought per class (even the asset is a knob). 0/absent => SHIP_LIGHT_HAULER /
  # SHIP_HEAVY_FREIGHTER.
  # ship_type_lights: SHIP_LIGHT_HAULER
  # ship_type_heavies: SHIP_HEAVY_FREIGHTER

  # API-utilization ceiling (dynamic protection; the fleet ceilings are the hard bound). Blocks buys
  # above this sustained request-utilization percent (0 => 85). Fails OPEN when unreadable.
  # api_utilization_ceiling_pct: 85

  # Zero-effect alarm: when demand persists this many consecutive ticks with NO purchase (blocked every
  # tick, or silent dry-run), emit ONE edge-triggered WARN naming the blocker (0 => 4). The mechanized
  # no-silent-dry-run lesson.
  # zero_effect_alarm_ticks: 4

  # WAREHOUSE hull class (sp-1txd M7/M8, opt-in via warehouse_hulls_enabled). Gate warehouse placement
  # on a chain's realized $/hr (rh2z chain_pnl) and N-tick score persistence so warehouses follow
  # DURABLE chains, not every tick's reshuffle. Capacity ladder buffer depth + module/frame ceilings.
  # warehouse_min_chain_realized_per_hour: 0
  # warehouse_min_chain_tick_persistence: 2
  # max_warehouse_hulls: 8
  # stocker_hulls_per_warehouse_group: 0
  # warehouse_capacity_target_hours: 2
  # max_module_spend_per_hull: 0
  # warehouse_frame_class_ceiling: light

# Captain bootstrap coordinator (sp-3nbe): the standing reconciler that drives a COLD agent through
# the cold-start arc to the jump gate — launched once via 'workflow bootstrap', it OBSERVES the live
# world each tick, DERIVES the phase from that observation (never a stored cursor), and ACTS on the
# delta behind guards, so a restart re-observes and resumes at real state. LIVE BY DEFAULT once
# launched (LAUNCH-GATED: nothing runs until you invoke 'workflow bootstrap'). DATA (probes -> target,
# scout every market) and INCOME (retire the frigate, hub-placed hauler ramp, batch-contract, $/hr
# exit) are live; GATE (construction) is a later slice.
bootstrap:
  # Escapes. bootstrap_disabled stands the WHOLE coordinator down (absent/false = ACTIVE, no
  # dark-shipping); the container stays resident so a flip + restart re-arms it. dry_run evaluates +
  # logs every decision LOUDLY (probe buys, scout assignments) but acts on nothing (also available as
  # the CLI --dry-run launch flag).
  # bootstrap_disabled: false
  # dry_run: false

  # DATA phase. probe_target is the probe count the coordinator ramps to, STAGED and capital-gated —
  # at most one buy per tick (0 => 3). coverage_bar is the DATA->INCOME exit threshold: the fraction
  # (0..1) of home-system marketplaces that must have fresh market data before the arc leaves DATA
  # (0 => 0.9). Contracts are blocked until data exists — the contract hubs are chosen FROM that data.
  # probe_target: 3
  # coverage_bar: 0.9

  # Money-guard + pacer. reserve_margin is the <=-fraction-of-treasury-per-decision guardrail: a buy
  # may spend at most this fraction of live treasury (leaving the rest as the working buffer), which
  # also PACES the acquisition ramp (0 => 0.5 = the <=50% rule). Fails CLOSED on an unreadable price.
  # reserve_margin: 0.5

  # Cadence + the asset. tick_seconds is the reconcile cadence (0 => 300 = 5min; cold-start is a slow,
  # deliberate ramp). probe_ship_type is the shipyard ship-type symbol bought for a probe (even the
  # asset is a knob; 0/absent => SHIP_PROBE).
  # tick_seconds: 300
  # probe_ship_type: SHIP_PROBE

  # INCOME phase (Slice 2). Past the coverage bar the coordinator retires the command frigate from
  # contract work (a poor contract worker: low fuel/cargo), selects contract hubs from the scouted
  # market data (central, market-dense waypoints where contract goods are cheaply sourceable), buys one
  # light hauler per viable hub (STAGED + capital-gated, placed on its hub), and runs batch-contract.
  # hauler_target caps the hull count (actual = one per viable hub, up to this; 0 => 4). hauler_ship_type
  # is the asset bought (0/absent => SHIP_LIGHT_HAULER).
  # hauler_target: 4
  # hauler_ship_type: SHIP_LIGHT_HAULER

  # income_bar is the INCOME->GATE exit: realized NET credits/hour the contract fleet must clear before
  # the arc drives gate construction (0 => 10000). Deliberately CONSERVATIVE — the Phase-1 objective is
  # building the gate, so a too-HIGH bar (the arc never reaching GATE) is the worse failure; this is the
  # primary field-calibration knob. min_contract_earners is how many haulers stay on contracts through
  # GATE to keep funding material acquisition (consumed in the GATE phase, Slice 3; 0 => 1).
  # income_bar: 10000
  # min_contract_earners: 1

  # GATE phase (Slice 3). Past the income bar the coordinator discovers the home-system jump-gate
  # construction site, drives `construction start` (the manufacturing coordinator — the executor — then
  # produces/acquires/delivers the materials), bounces that executor so it ADOPTS the fresh pipeline
  # (captain L57), sizes gate-construction workers deterministically (REPURPOSING idle contract haulers
  # beyond min_contract_earners to the manufacturing fleet FIRST, then buying the delta only if short),
  # and monitors construction to 100% -> COMPLETE (where it launches the fleet-autosizer + standing
  # coordinators as the hand-off, then exits). gate_worker_target caps the workers (actual = ~one per
  # active gate-material chain + a delivery hauler, up to this; 0 => 6). Gate workers reuse
  # hauler_ship_type. The autosizer stays OFF the whole bootstrap run and is launched only at COMPLETE.
  # gate_worker_target: 6

# Capacity reconciler (epic st-7zk): the standing declarative engine that drives the
# contract-delivery machine's ACTUAL capacity topology toward a computed DESIRED topology
# (SENSE -> PLAN -> DIFF -> GOVERN -> CONVERGE), maximizing per-hull-sustained $/hr with
# cycle-time as the lever. EXPLICIT START ONLY ('workflow capacity-reconciler') — a fresh deploy
# never arms it. Cheap moves (reuse idle hulls, rebalance, buffer caps) execute autonomously;
# capital moves (add cluster, autobuy) file PROPOSALS for approval (tiered autonomy v1).
# Honors captain/DISABLED at the top of EVERY tick. Every knob 0/absent => the documented
# protective default; out-of-range explicit values fail the launch loudly.
capacity_reconciler:
  # Capex governor. reserve_floor is the HARD treasury floor in credits — never spend below it
  # (0 => 50000, the immutable floor). surplus_fraction is f in the per-cycle deployable budget
  # f × (treasury − floor) (0 => 0.25). per_decision_cap_pct caps ONE capital decision at this
  # percent of the deployable budget (0 => 25, spec-locked).
  # reserve_floor: 50000
  # surplus_fraction: 0.25
  # per_decision_cap_pct: 25

  # ROI gates. roi_payback_horizon_hours: a capital item must pay itself back within this window
  # (0 => 24). add_threshold_per_hull_cr_hr: a capacity add must keep fleet per-hull credits/hr
  # above this floor (0 => no explicit floor; the raise-the-average absorption ceiling still
  # applies).
  # roi_payback_horizon_hours: 24
  # add_threshold_per_hull_cr_hr: 0

  # Buffer selection. stocker_capacity_budget is the per-hub stocker-capacity budget (units of
  # buffered volume) the planner selects buffer goods under (0 => planner default).
  # stocker_capacity_budget: 0

  # Pacing + autonomy. tick_interval_secs is the reconcile cadence (0 => 300 = 5min; capacity
  # topology is strategic). approval_threshold is the capex-proposal approval threshold in
  # credits: a tier-4 action costing at least this files a proposal instead of auto-executing
  # (0 => EVERY capital action needs approval — tiered autonomy v1; raise it later to graduate).
  # tick_interval_secs: 300
  # approval_threshold: 0
