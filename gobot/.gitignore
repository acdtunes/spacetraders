# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.txt
coverage.html

# Test output files
test_output.txt
test_results*.txt
/tmp/test_*.txt

# Captain self-improvement worktrees
.captain-worktrees/

# Dependency directories
vendor/

# Go workspace file
go.work

# Build artifacts
/bin/
/dist/
/bin/spacetraders
/bin/spacetraders-daemon

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local

# Database
*.db
*.sqlite
*.sqlite3

# Logs
*.log
/logs/

# Generated protobuf files
# *.pb.go — generated protobuf stubs ARE tracked: gitignoring them let
# auto-merged .proto changes pass the gate (regenerated in-worktree) then
# break main (stale stubs). Committing them keeps gate == main.

# Unix socket
*.sock
/var/run/spacetraders.sock

# MCP Server (TypeScript)
/mcp/node_modules/
/mcp/build/
/mcp/var/

# Python routing service generated files
services/routing-service/generated/*.py
!services/routing-service/generated/__init__.py
config.yaml
