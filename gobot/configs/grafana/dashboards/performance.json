    {
      "datasource": {
        "type": "datasource",
        "uid": "-- Mixed --"
      },
      "description": "Program KPI (sp-qxx4): hourly $/request trend = net profit (Postgres, all txns/hr, same 'net (all-in)' definition used in financial.json) / API requests (Prometheus, hourly increase), joined via Grafana server-side Math expression on matching bucket timestamps. Prometheus currently retains only ~4-5h of request history post-deploy, so this fills sparse-to-full over the next ~24h as retention accumulates (same caveat as the Manufacturing Task Completions panel).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "unit": "locale",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 39
      },
      "id": 17,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(created_at, '1h'), COALESCE(SUM(amount), 0) AS net_profit FROM transactions WHERE $__timeFilter(created_at) AND player_id=(SELECT MAX(id) FROM players) GROUP BY 1 ORDER BY 1",
          "hide": true
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
