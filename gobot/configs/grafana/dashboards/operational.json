    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgresql"
      },
      "description": "Terminal container outcomes per command_type. High corpse % = a lane crash-looping instead of working.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 37,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT command_type AS \"Command\", COUNT(*) FILTER (WHERE status = 'FAILED') AS \"Failed\", COUNT(*) FILTER (WHERE status = 'COMPLETED') AS \"Completed\", COUNT(*) FILTER (WHERE status = 'STOPPED') AS \"Stopped\", ROUND(100.0 * COUNT(*) FILTER (WHERE status = 'FAILED') / NULLIF(COUNT(*) FILTER (WHERE status IN ('FAILED', 'COMPLETED', 'STOPPED')), 0), 1) AS \"Corpse %\" FROM containers WHERE stopped_at >= NOW() - INTERVAL '24 hours' AND player_id=(SELECT MAX(id) FROM players) GROUP BY 1 ORDER BY \"Failed\" DESC",
          "refId": "A"
        }
      ],
      "title": "Corpse Rate by Command (24h)",
      "type": "table"
    },
