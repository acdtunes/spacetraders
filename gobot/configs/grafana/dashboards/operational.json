          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(stopped_at, '15m'), command_type AS metric, COUNT(*) AS \"failures\" FROM containers WHERE $__timeFilter(stopped_at) AND status = 'FAILED' AND player_id=(SELECT MAX(id) FROM players) GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Container Failures per 15m by Command",
      "type": "timeseries"
