          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT stopped_at AS \"When\", command_type AS \"Command\", LEFT(COALESCE(exit_reason, '(none)'), 140) AS \"Reason\" FROM containers WHERE status = 'FAILED' AND stopped_at >= NOW() - INTERVAL '6 hours' AND command_type IN ('scout_tour', 'scout_reposition', 'tour_run', 'navigate_ship', 'dock_ship', 'orbit_ship', 'trade_route') ORDER BY stopped_at DESC LIMIT 20",
          "refId": "A"
        }
      ],
