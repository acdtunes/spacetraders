          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(stopped_at, '15m'), command_type AS metric, COUNT(*) AS \"failures\" FROM containers WHERE $__timeFilter(stopped_at) AND status = 'FAILED' AND command_type IN ('scout_tour', 'scout_reposition', 'tour_run', 'navigate_ship', 'dock_ship', 'orbit_ship', 'trade_route') GROUP BY 1, 2 ORDER BY 1",
