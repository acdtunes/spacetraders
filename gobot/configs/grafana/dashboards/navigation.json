    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgresql"
      },
      "description": "% of standing scout posts whose WORST market age is within the post's freshness target.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 0,
        "y": 9
      },
      "id": 23,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(ROUND(100.0 * COUNT(*) FILTER (WHERE max_age <= freshness_target_seconds) / NULLIF(COUNT(*), 0)), 0) FROM (SELECT sp.system_symbol, sp.freshness_target_seconds, MAX(EXTRACT(EPOCH FROM (NOW() - md.last_updated))) AS max_age FROM scout_posts sp JOIN market_data md ON SPLIT_PART(md.waypoint_symbol, '-', 1) || '-' || SPLIT_PART(md.waypoint_symbol, '-', 2) = sp.system_symbol AND md.player_id = sp.player_id WHERE sp.kind = 'standing' AND sp.player_id=(SELECT MAX(id) FROM players) GROUP BY 1, 2) t",
          "refId": "A"
        }
      ],
      "title": "Standing Posts Meeting Target",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgresql"
      },
      "description": "THE freshness measure: market_data age per posted system vs the scout post's own target. Sorted worst-first.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 14,
        "x": 4,
        "y": 9
      },
      "id": 24,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT sp.system_symbol AS \"System\", sp.kind AS \"Kind\", sp.hulls AS \"Hulls\", sp.freshness_target_seconds AS \"Target (s)\", COUNT(DISTINCT md.waypoint_symbol) AS \"Markets\", ROUND(AVG(EXTRACT(EPOCH FROM (NOW() - md.last_updated)))) AS \"Avg Age (s)\", ROUND(MAX(EXTRACT(EPOCH FROM (NOW() - md.last_updated)))) AS \"Max Age (s)\", CASE WHEN MAX(EXTRACT(EPOCH FROM (NOW() - md.last_updated))) <= sp.freshness_target_seconds THEN 'FRESH' WHEN AVG(EXTRACT(EPOCH FROM (NOW() - md.last_updated))) <= sp.freshness_target_seconds THEN 'PARTIAL' ELSE 'STALE' END AS \"Status\" FROM scout_posts sp LEFT JOIN market_data md ON SPLIT_PART(md.waypoint_symbol, '-', 1) || '-' || SPLIT_PART(md.waypoint_symbol, '-', 2) = sp.system_symbol AND md.player_id = sp.player_id WHERE sp.player_id=(SELECT MAX(id) FROM players) GROUP BY sp.system_symbol, sp.kind, sp.hulls, sp.freshness_target_seconds ORDER BY MAX(EXTRACT(EPOCH FROM (NOW() - md.last_updated))) DESC NULLS FIRST",
          "refId": "A"
        }
      ],
      "title": "Market Freshness vs Post Target (by system)",
      "type": "table"
    },
