      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH fleet_inv AS (SELECT s.ship_symbol, g->>'symbol' AS good, (g->>'units')::int AS units FROM ships s, jsonb_array_elements(s.cargo_inventory::jsonb) g WHERE s.cargo_units > 0 AND s.player_id=(SELECT MAX(id) FROM players) AND NOT EXISTS (SELECT 1 FROM storage_operations so, jsonb_array_elements_text(so.storage_ships::jsonb) ss(ship_symbol) WHERE so.status='RUNNING' AND so.player_id=(SELECT MAX(id) FROM players) AND ss.ship_symbol = s.ship_symbol)), px AS (SELECT good_symbol, MAX(purchase_price) AS best_bid FROM market_data WHERE player_id=(SELECT MAX(id) FROM players) GROUP BY 1) SELECT COALESCE(SUM(f.units*COALESCE(p.best_bid,0)), 0) AS \"value\" FROM fleet_inv f LEFT JOIN px p ON p.good_symbol=f.good",
          "refId": "A"
        }
      ],
      "title": "In-Transit / Working Value",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgresql"
      },
      "description": "Per-good breakdown of the fleet total above: units held, best-known bid, mark-to-bid value, and the stored share (aboard warehouse hulls per storage_operations.storage_ships, RUNNING) vs in-transit/working. Sorted by value. Valuation is an optimistic ceiling \u2014 realized value depends on market absorption; stored goods are a total loss at an era reset.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
