            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH buckets AS (SELECT date_bin('15 minutes', created_at, TIMESTAMPTZ '2001-01-01') AS b, SUM(amount) * 4 AS rate FROM transactions WHERE created_at > $__timeFrom()::timestamptz - INTERVAL '6 hours' AND created_at < $__timeTo()::timestamptz AND created_at < date_bin('15 minutes', now(), TIMESTAMPTZ '2001-01-01') AND category != 'SHIP_INVESTMENTS' AND player_id=(SELECT MAX(id) FROM players) GROUP BY 1), smoothed AS (SELECT b, AVG(rate) OVER (ORDER BY b ROWS BETWEEN 11 PRECEDING AND CURRENT ROW) AS \"operating 3h avg\", AVG(rate) OVER (ORDER BY b ROWS BETWEEN 23 PRECEDING AND CURRENT ROW) AS \"operating 6h avg\" FROM buckets) SELECT b AS \"time\", \"operating 3h avg\", \"operating 6h avg\" FROM smoothed WHERE b >= date_bin('15 minutes', $__timeFrom()::timestamptz, TIMESTAMPTZ '2001-01-01') ORDER BY b",
          "refId": "A"
        }
      ],
      "title": "Operating Profit/hr - Smoothed (3h/6h trailing)",
      "type": "timeseries"
    },
