    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgresql"
      },
      "description": "Trailing moving average of operating profit (ex-capex) in cr/hr over 15-minute buckets: 3h = 12-point, 6h = 24-point trailing mean. Reads the trend through the lumpy tour buy/sell texture (raw 15m rate swings by millions; the 24-point mean's median step-to-step move is ~47k). Each 15m bucket SUM is x4 to stay in cr/hr. The moving average is computed over a 6h-widened input in a first CTE then clipped to the visible range in the outer query (so the leftmost points average over real prior history rather than a starved frame), and the current incomplete 15m bucket is excluded so the right edge does not dive.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "unit": "locale",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 10,
        "x": 14,
        "y": 48
      },
      "id": 104,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH buckets AS (SELECT date_bin('15 minutes', created_at, TIMESTAMPTZ '2001-01-01') AS b, SUM(amount) * 4 AS rate FROM transactions WHERE created_at > $__timeFrom()::timestamptz - INTERVAL '6 hours' AND created_at < $__timeTo()::timestamptz AND created_at < date_bin('15 minutes', now(), TIMESTAMPTZ '2001-01-01') AND category != 'SHIP_INVESTMENTS' GROUP BY 1), smoothed AS (SELECT b, AVG(rate) OVER (ORDER BY b ROWS BETWEEN 11 PRECEDING AND CURRENT ROW) AS \"operating 3h avg\", AVG(rate) OVER (ORDER BY b ROWS BETWEEN 23 PRECEDING AND CURRENT ROW) AS \"operating 6h avg\" FROM buckets) SELECT b AS \"time\", \"operating 3h avg\", \"operating 6h avg\" FROM smoothed WHERE b >= date_bin('15 minutes', $__timeFrom()::timestamptz, TIMESTAMPTZ '2001-01-01') ORDER BY b",
          "refId": "A"
        }
      ],
      "title": "Operating Profit/hr - Smoothed (3h/6h trailing)",
      "type": "timeseries"
    },
