        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH fleet_inv AS (SELECT s.ship_symbol, g->>'symbol' AS good, (g->>'units')::int AS units FROM ships s, jsonb_array_elements(s.cargo_inventory::jsonb) g WHERE s.cargo_units > 0 AND s.player_id=(SELECT MAX(id) FROM players) AND EXISTS (SELECT 1 FROM storage_operations so, jsonb_array_elements_text(so.storage_ships::jsonb) ss(ship_symbol) WHERE so.status='RUNNING' AND so.player_id=(SELECT MAX(id) FROM players) AND ss.ship_symbol = s.ship_symbol)), px AS (SELECT good_symbol, MAX(purchase_price) AS best_bid FROM market_data WHERE player_id=(SELECT MAX(id) FROM players) GROUP BY 1) SELECT COALESCE(SUM(f.units*COALESCE(p.best_bid,0)), 0) AS \"value\" FROM fleet_inv f LEFT JOIN px p ON p.good_symbol=f.good",
          "refId": "A"
        }
      ],
      "title": "Stored Value",
      "type": "stat"
    },
