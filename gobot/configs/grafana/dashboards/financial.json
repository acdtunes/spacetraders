        "x": 0,
        "y": 7
      },
      "id": 111,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH fleet_inv AS (SELECT g->>'symbol' AS good, SUM((g->>'units')::int) AS units FROM ships, jsonb_array_elements(cargo_inventory::jsonb) g WHERE cargo_units > 0 AND player_id=(SELECT MAX(id) FROM players) GROUP BY 1), px AS (SELECT good_symbol, MAX(purchase_price) AS best_bid FROM market_data WHERE player_id=(SELECT MAX(id) FROM players) GROUP BY 1) SELECT COALESCE(SUM(f.units*COALESCE(p.best_bid,0)), 0) AS \"value\" FROM fleet_inv f LEFT JOIN px p ON p.good_symbol=f.good",
          "refId": "A"
        }
      ],
      "title": "Fleet Inventory Value",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
