    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "postgresql"
      },
      "description": "Total value of all cargo currently aboard the fleet (in transit + stored), marked to the best-known bid (MAX purchase_price) across scouted markets per good. This is an OPTIMISTIC CEILING, not a guaranteed realization \u2014 selling this much volume would move prices and may exceed what markets can actually absorb. Goods with no scouted market price at 0.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "unit": "locale",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
