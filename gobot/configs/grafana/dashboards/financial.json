          "rawSql": "SELECT metadata->>'ship_symbol' AS \"Ship\", SUM(amount) AS \"Net\", COALESCE(SUM(amount) FILTER (WHERE category='TRADING_REVENUE'), 0) AS \"Revenue\", COALESCE(-SUM(amount) FILTER (WHERE category IN ('TRADING_COSTS','FUEL_COSTS')), 0) AS \"Costs\", COUNT(DISTINCT related_entity_id) AS \"Runs\" FROM transactions WHERE operation_type='tour' AND created_at >= NOW() - INTERVAL '6 hours' AND player_id=(SELECT MAX(id) FROM players) AND metadata->>'ship_symbol' IS NOT NULL GROUP BY 1 ORDER BY SUM(amount) DESC",
          "refId": "A"
        }
      ],
      "title": "Per-Heavy Tour Profit (6h)",
      "type": "table"
