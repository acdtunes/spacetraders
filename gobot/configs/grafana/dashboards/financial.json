          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH buckets AS (SELECT date_trunc('hour', created_at) AS b, SUM(amount) AS hourly FROM transactions WHERE created_at > $__timeFrom()::timestamptz - INTERVAL '6 hours' AND created_at < $__timeTo()::timestamptz AND category != 'SHIP_INVESTMENTS' AND player_id=(SELECT MAX(id) FROM players) GROUP BY 1) SELECT b AS \"time\", AVG(hourly) OVER (ORDER BY b ROWS BETWEEN 2 PRECEDING AND CURRENT ROW) AS \"operating 3h avg\", AVG(hourly) OVER (ORDER BY b ROWS BETWEEN 5 PRECEDING AND CURRENT ROW) AS \"operating 6h avg\" FROM buckets WHERE b >= date_trunc('hour', $__timeFrom()::timestamptz) ORDER BY b",
          "refId": "A"
        }
      ],
      "title": "Operating Profit/hr - Smoothed (3h/6h trailing)",
