      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgresql"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH fleet_inv AS (SELECT s.ship_symbol, g->>'symbol' AS good, (g->>'units')::int AS units, EXISTS (SELECT 1 FROM storage_operations so, jsonb_array_elements_text(so.storage_ships::jsonb) ss(ship_symbol) WHERE so.status='RUNNING' AND so.player_id=(SELECT MAX(id) FROM players) AND ss.ship_symbol = s.ship_symbol) AS is_stored FROM ships s, jsonb_array_elements(s.cargo_inventory::jsonb) g WHERE s.cargo_units > 0 AND s.player_id=(SELECT MAX(id) FROM players)), agg AS (SELECT good, SUM(units) AS units, SUM(units) FILTER (WHERE is_stored) AS stored_units FROM fleet_inv GROUP BY 1), px AS (SELECT good_symbol, MAX(purchase_price) AS best_bid FROM market_data WHERE player_id=(SELECT MAX(id) FROM players) GROUP BY 1) SELECT a.good AS \"Good\", a.units AS \"Units\", COALESCE(p.best_bid,0) AS \"Best Bid\", a.units*COALESCE(p.best_bid,0) AS \"Value\", ROUND(100.0*COALESCE(a.stored_units,0)/NULLIF(a.units,0),1) AS \"Stored %\" FROM agg a LEFT JOIN px p ON p.good_symbol=a.good ORDER BY 4 DESC",
          "refId": "A"
        }
      ],
      "title": "Inventory by Good",
      "type": "table"
    },
