+def _cleanup_stranded_cargo(ship: ShipController, api: APIClient, logger: logging.Logger) -> bool:
+    """
+    Emergency cleanup: Sell all stranded cargo at any price to recover credits
+
+    This function ALWAYS runs before circuit breaker exits to prevent cargo from
+    becoming stranded on ships when operations abort.
+
+    Args:
+        ship: ShipController instance
+        api: APIClient instance
+        logger: Logger instance
+
+    Returns:
+        True if cleanup succeeded (or no cargo to clean), False on failure
+    """
+    # Check if ship has cargo
+    ship_data = ship.get_status()
+    if not ship_data:
+        logger.error("Failed to get ship status during cargo cleanup")
+        return False
+
+    cargo = ship_data['cargo']
+    inventory = cargo.get('inventory', [])
+
+    if not inventory or cargo.get('units', 0) == 0:
+        logger.debug("No stranded cargo to clean up")
+        return True
+
+    # Ship has stranded cargo - we MUST sell it
+    logger.warning("="*70)
+    logger.warning("🧹 EMERGENCY CARGO CLEANUP")
+    logger.warning("="*70)
+    logger.warning(f"Ship has {cargo['units']} units of stranded cargo:")
+    for item in inventory:
+        logger.warning(f"  - {item['units']}x {item['symbol']}")
+    logger.warning("Selling at ANY price to recover credits...")
+    logger.warning("="*70)
+
+    # Dock if needed (must be docked to sell)
+    if ship_data['nav']['status'] != 'DOCKED':
+        logger.info("Docking to sell stranded cargo...")
+        if not ship.dock():
+            logger.error("❌ Failed to dock for cargo cleanup")
+            return False
+
+    # Sell all cargo items
+    total_recovered = 0
+    for item in inventory:
+        good = item['symbol']
+        units = item['units']
+
+        logger.info(f"Selling {units}x {good}...")
+
+        try:
+            # Sell cargo at ANY price to recover credits
+            transaction = ship.sell(good, units)
+            if transaction:
+                revenue = transaction['totalPrice']
+                total_recovered += revenue
+                logger.info(f"✅ Sold {units}x {good} for {revenue:,} credits")
+            else:
+                logger.error(f"❌ Failed to sell {good}")
+                # Continue trying to sell other items
+        except Exception as e:
+            logger.error(f"❌ Error selling {good}: {e}")
+            # Continue trying to sell other items
+
+    # Verify cargo is empty
+    final_status = ship.get_status()
+    if final_status and final_status['cargo'].get('units', 0) == 0:
+        logger.info("="*70)
+        logger.info(f"✅ CLEANUP COMPLETE - Recovered {total_recovered:,} credits")
+        logger.info("="*70)
+        return True
+    else:
+        logger.warning("⚠️  Some cargo may remain - cleanup partially failed")
+        return False
+
