from pytest_bdd import scenarios, given, when, then, parsers
from unittest.mock import Mock, patch, MagicMock
import io
import sys
import json
import tempfile
from pathlib import Path

from spacetraders_bot.operations.routing import (
    graph_build_operation,
    route_plan_operation,
)

scenarios('../../../bdd/features/operations/routing.feature')


class MockGraphBuilder:
    """Mock graph builder."""
    def __init__(self, api):
        self.api = api
        self.graph_data = None

    def build_system_graph(self, system):
        """Build graph."""
        if not self.graph_data:
            return None
        return self.graph_data

    def load_system_graph(self, system):
        """Load graph."""
        return self.graph_data


class MockRouteOptimizer:
    """Mock route optimizer."""
    def __init__(self, graph, ship_data):
        self.graph = graph
        self.ship_data = ship_data
        self.route_data = None

    def find_optimal_route(self, start, goal, fuel):
        """Find route."""
        if not self.route_data:
            return None
        return self.route_data


class MockDatabase:
    """Mock database."""
    def __init__(self):
        self.graphs = {}

    def connection(self):
        """Return mock connection context manager."""
        class MockConnection:
            def __init__(self, db):
                self.db = db

            def __enter__(self):
                return self

            def __exit__(self, *args):
                pass

        return MockConnection(self)

    def get_system_graph(self, conn, system):
        """Get graph from database."""
        return self.graphs.get(system)


@given('a routing system', target_fixture='routing_ctx')
def given_routing_system():
    """Create routing system."""
    return {
        'graph_builder': None,
        'route_optimizer': None,
        'database': None,
        'result_code': None,
        'output': '',
        'args': None,
        'saved_file': None,
        'routing_paused': False,
    }


@given(parsers.re(r'system "(?P<system>[^"]+)" has waypoints in database'))
def given_system_waypoints(routing_ctx, system):
    """System has waypoints."""
    routing_ctx['graph_data'] = {
        'system': system,
        'waypoints': {
            f'{system}-A1': {'x': 0, 'y': 0, 'has_fuel': True},
            f'{system}-B5': {'x': 10, 'y': 10, 'has_fuel': False},
        },
        'edges': [
            {'from': f'{system}-A1', 'to': f'{system}-B5', 'distance': 14.14}
        ]
    }


@given(parsers.re(r'system "(?P<system>[^"]+)" has (?P<count>\d+) waypoints'))
def given_system_waypoint_count(routing_ctx, system, count):
    """System has N waypoints."""
    waypoints = {}
    for i in range(int(count)):
        wp_id = f'{system}-W{i+1}'
        waypoints[wp_id] = {'x': i, 'y': i, 'has_fuel': False}

    routing_ctx['graph_data'] = {
        'system': system,
        'waypoints': waypoints,
        'edges': []
    }


@given(parsers.re(r'(?P<count>\d+) waypoints? have fuel stations'))
def given_fuel_stations(routing_ctx, count):
    """N waypoints have fuel."""
    graph = routing_ctx.get('graph_data', {})
    waypoints = graph.get('waypoints', {})

    fuel_count = 0
    for wp_id in list(waypoints.keys()):
        if fuel_count < int(count):
            waypoints[wp_id]['has_fuel'] = True
            fuel_count += 1


@given(parsers.re(r'system "(?P<system>[^"]+)" has graph in database'))
def given_graph_in_database(routing_ctx, system):
    """Graph exists in database."""
    if 'database' not in routing_ctx or not routing_ctx['database']:
        routing_ctx['database'] = MockDatabase()

    # Create graph data if not exists
    if 'graph_data' not in routing_ctx:
        routing_ctx['graph_data'] = {
            'system': system,
            'waypoints': {
                f'{system}-A1': {'x': 0, 'y': 0, 'has_fuel': True},
                f'{system}-B5': {'x': 10, 'y': 10, 'has_fuel': False},
            },
            'edges': [
                {'from': f'{system}-A1', 'to': f'{system}-B5', 'distance': 14.14}
            ]
        }

    routing_ctx['database'].graphs[system] = routing_ctx['graph_data']


@given(parsers.re(r'system "(?P<system>[^"]+)" has graph with route'))
def given_graph_with_route(routing_ctx, system):
    """Graph has route."""
    # First set up graph
    given_graph_in_database(routing_ctx, system)

    # Add route data
    routing_ctx['route_data'] = {
        'total_time': 1000,
        'final_fuel': 90,
        'steps': [
            {
                'action': 'navigate',
                'from': f'{system}-A1',
                'to': f'{system}-B5',
                'mode': 'CRUISE',
                'distance': 14.14,
                'time': 1000,
                'fuel_cost': 10
            }
        ]
    }


@given(parsers.re(r'system "(?P<system>[^"]+)" has no graph in database'))
def given_no_graph(routing_ctx, system):
    """No graph in database."""
    if 'database' not in routing_ctx or not routing_ctx['database']:
        routing_ctx['database'] = MockDatabase()
    # Don't add graph to database


@given(parsers.re(r'ship "(?P<ship>[^"]+)" is at waypoint "(?P<waypoint>[^"]+)"'))
def given_ship_at_waypoint(routing_ctx, ship, waypoint):
    """Ship at waypoint."""
    routing_ctx['ship_data'] = {
        'symbol': ship,
        'nav': {'waypointSymbol': waypoint},
        'frame': {'symbol': 'FRAME_LIGHT_FREIGHTER'},
        'engine': {'symbol': 'ENGINE_ION_DRIVE_I', 'speed': 10},
        'fuel': {'current': 100, 'capacity': 100}
    }


@given(parsers.re(r'ship "(?P<ship>[^"]+)" has fuel (?P<current>\d+)/(?P<capacity>\d+)'))
def given_ship_fuel(routing_ctx, ship, current, capacity):
    """Ship has fuel."""
    if 'ship_data' not in routing_ctx:
        routing_ctx['ship_data'] = {
            'symbol': ship,
            'nav': {'waypointSymbol': 'X1-TEST-A1'},
            'frame': {'symbol': 'FRAME_LIGHT_FREIGHTER'},
            'engine': {'symbol': 'ENGINE_ION_DRIVE_I', 'speed': 10},
        }
    routing_ctx['ship_data']['fuel'] = {
        'current': int(current),
        'capacity': int(capacity)
    }


@given('routing is paused')
def given_routing_paused(routing_ctx):
    """Routing is paused."""
    routing_ctx['routing_paused'] = True


@when(parsers.re(r'I build graph for system "(?P<system>[^"]+)"'))
def when_build_graph(routing_ctx, system):
    """Build graph."""
    args = Mock()
    args.player_id = 1
    args.system = system
    args.log_level = 'ERROR'

    routing_ctx['args'] = args
    _run_graph_build(routing_ctx, args)


@when(parsers.re(r'I plan route from "(?P<start>[^"]+)" to "(?P<goal>[^"]+)"$'))
def when_plan_route(routing_ctx, start, goal):
    """Plan route."""
    args = Mock()
    args.player_id = 1
    args.system = start.rsplit('-', 1)[0]  # Extract system from waypoint
    args.ship = routing_ctx.get('ship_data', {}).get('symbol', 'SHIP-1')
    args.start = start
    args.goal = goal
    args.output = None
    args.log_level = 'ERROR'

    routing_ctx['args'] = args
    _run_route_plan(routing_ctx, args)


@when(parsers.re(r'I plan route from "(?P<start>[^"]+)" to "(?P<goal>[^"]+)" with output "(?P<output>[^"]+)"'))
def when_plan_route_with_output(routing_ctx, start, goal, output):
    """Plan route with output."""
    # Create temp file for output
    temp_dir = tempfile.mkdtemp()
    output_path = Path(temp_dir) / output

    args = Mock()
    args.player_id = 1
    args.system = start.rsplit('-', 1)[0]
    args.ship = routing_ctx.get('ship_data', {}).get('symbol', 'SHIP-1')
    args.start = start
    args.goal = goal
    args.output = str(output_path)
    args.log_level = 'ERROR'

    routing_ctx['args'] = args
    routing_ctx['saved_file'] = output_path
    _run_route_plan(routing_ctx, args)


def _run_graph_build(routing_ctx, args):
    """Run graph build operation."""
    # Capture stdout
    captured_output = io.StringIO()
    sys.stdout = captured_output

    # Create mock API
    api = Mock()

    # Create mock graph builder
    builder = MockGraphBuilder(api)
    builder.graph_data = routing_ctx.get('graph_data')

    # Mock the API client and GraphBuilder
    with patch('spacetraders_bot.operations.routing.get_api_client', return_value=api):
        with patch('spacetraders_bot.operations.routing.GraphBuilder', return_value=builder):
            result = graph_build_operation(args)

    # Restore stdout
    sys.stdout = sys.__stdout__

    routing_ctx['output'] = captured_output.getvalue()
    routing_ctx['result_code'] = result


def _run_route_plan(routing_ctx, args):
    """Run route plan operation."""
    # Capture stdout
    captured_output = io.StringIO()
    sys.stdout = captured_output

    # Create mocks
    api = Mock()
    api.get_ship = Mock(return_value=routing_ctx.get('ship_data'))

    db = routing_ctx.get('database') or MockDatabase()

    # Create mock optimizer
    ship_data = routing_ctx.get('ship_data', {})
    graph = routing_ctx.get('graph_data')

    optimizer = MockRouteOptimizer(graph, ship_data)
    optimizer.route_data = routing_ctx.get('route_data')

    # Mock routing pause
    def mock_is_paused():
        return routing_ctx.get('routing_paused', False)

    def mock_pause_details():
        if routing_ctx.get('routing_paused'):
            return {'reason': 'Validation failure'}
        return None

    # Patch all dependencies
    with patch('spacetraders_bot.operations.routing.get_api_client', return_value=api):
        with patch('spacetraders_bot.operations.routing.Database', return_value=db):
            with patch('spacetraders_bot.operations.routing.GraphBuilder') as mock_builder_class:
                mock_builder = Mock()
                mock_builder.build_system_graph = Mock(return_value=graph)
                mock_builder_class.return_value = mock_builder

                with patch('spacetraders_bot.operations.routing.RouteOptimizer', return_value=optimizer):
                    with patch('spacetraders_bot.operations.routing.routing_paused', side_effect=mock_is_paused):
                        with patch('spacetraders_bot.operations.routing.get_pause_details', side_effect=mock_pause_details):
                            result = route_plan_operation(args)

    # Restore stdout
    sys.stdout = sys.__stdout__

    routing_ctx['output'] = captured_output.getvalue()
    routing_ctx['result_code'] = result


@then('graph should be built successfully')
def then_graph_built(routing_ctx):
    """Verify graph built."""
    assert routing_ctx['result_code'] == 0


@then('output should show waypoint count')
def then_show_waypoint_count(routing_ctx):
    """Verify waypoint count shown."""
    assert 'Waypoints:' in routing_ctx['output']


@then('output should show edge count')
def then_show_edge_count(routing_ctx):
    """Verify edge count shown."""
    assert 'Edges:' in routing_ctx['output']


@then(parsers.re(r'output should show "(?P<count>\d+)" fuel stations'))
def then_show_fuel_stations(routing_ctx, count):
    """Verify fuel station count."""
    assert f'Fuel stations: {count}' in routing_ctx['output']


@then('route should be found')
def then_route_found(routing_ctx):
    """Verify route found."""
    assert routing_ctx['result_code'] == 0


@then('output should show total time')
def then_show_total_time(routing_ctx):
    """Verify total time shown."""
    assert 'Total time:' in routing_ctx['output']


@then('output should show final fuel')
def then_show_final_fuel(routing_ctx):
    """Verify final fuel shown."""
    assert 'Final fuel:' in routing_ctx['output']


@then('output should show navigation steps')
def then_show_navigation_steps(routing_ctx):
    """Verify navigation steps shown."""
    assert 'NAVIGATE' in routing_ctx['output']


@then('steps should include distance')
def then_steps_include_distance(routing_ctx):
    """Verify steps include distance."""
    assert 'Distance:' in routing_ctx['output']


@then('steps should include fuel cost')
def then_steps_include_fuel_cost(routing_ctx):
    """Verify steps include fuel cost."""
    assert 'Fuel: -' in routing_ctx['output']


@then('route planning should fail')
def then_route_planning_fails(routing_ctx):
    """Verify route planning failed."""
    assert routing_ctx['result_code'] == 1


@then('output should show graph not found')
def then_show_graph_not_found(routing_ctx):
    """Verify graph not found message."""
    assert 'Graph not found' in routing_ctx['output'] or 'Building graph now' in routing_ctx['output']


@then('output should show routing paused')
def then_show_routing_paused(routing_ctx):
    """Verify routing paused message."""
    assert 'Routing is paused' in routing_ctx['output']


@then('route should be saved to file')
def then_route_saved(routing_ctx):
    """Verify route saved."""
    saved_file = routing_ctx.get('saved_file')
    if saved_file and saved_file.exists():
        assert True
    else:
        # Check output message
        assert 'Route saved to:' in routing_ctx['output']


@then('saved route should contain steps')
def then_saved_route_contains_steps(routing_ctx):
    """Verify saved route contains steps."""
    saved_file = routing_ctx.get('saved_file')
    if saved_file and saved_file.exists():
        with open(saved_file) as f:
            data = json.load(f)
        assert 'steps' in data
    else:
        # Just check the operation succeeded
        assert routing_ctx['result_code'] == 0
