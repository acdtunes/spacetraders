[run]
source = src/spacetraders_bot
branch = True
omit =
    */tests/*
    */conftest.py
    */__pycache__/*
    */routing_legacy.py

[report]
precision = 1
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

[html]
directory = htmlcov

[json]
output = coverage.json
